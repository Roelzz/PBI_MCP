# Azure AD (Service Principal)
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# Certificate auth (preferred over CLIENT_SECRET, leave blank to use secret)
CLIENT_CERT_PATH=
CLIENT_CERT_PASSPHRASE=

# Auth mode: "none" (client credentials only) or "obo" (Azure AD JWT + OBO)
AUTH_MODE=none
MCP_BASE_URL=

# MCP Server
MCP_TRANSPORT=http
MCP_PORT=2009

# Application
LOG_LEVEL=INFO
